{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm run typecheck && pnpm --filter @workspace/chess-coach run build",
  "outputDirectory": "artifacts/chess-coach/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://chess-performance-analyzer.replit.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
